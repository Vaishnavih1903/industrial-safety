import axios from "axios";

const API =
"https://web-production-337b7.up.railway.app";

export async function analyzeRisk(data){

try{

const response=

await axios.post(

`${API}/sensor`,

data,

{
headers:{
"Content-Type":
"application/json"
}
}

);

return response.data;

}

catch(error){

console.log(error);

throw error;

}

}