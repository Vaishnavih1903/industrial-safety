import axios from "axios";

const API =
"https://web-production-337b7.up.railway.app";

export async function analyzeRisk(data){

try{

console.log("Sending:",data);

const response=

await axios.post(
`${API}/sensor`,
data
);

console.log(
"Response:",
response.data
);

return response.data;

}

catch(error){

console.log(
"ERROR:"
);

console.log(
error.response?.data
);

console.log(
error
);

throw error;

}

}